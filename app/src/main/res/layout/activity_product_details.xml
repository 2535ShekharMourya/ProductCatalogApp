    <ImageView
        android:id="@+id/product_image"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_300sdp"
        android:src="@drawable/share"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout" />

    <!-- Brand -->
    <TextView
        android:id="@+id/txtBrand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="APPLE"
        android:textColor="#3F6BFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="@dimen/_8sdp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/product_image" />

    <!-- Stock Badge -->
    <TextView
        android:id="@+id/txtStock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IN STOCK"
        android:textColor="#1B5E20"
        android:textSize="12sp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        app:layout_constraintTop_toTopOf="@id/txtBrand"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Product Title -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="iPhone 13 - Pro Blue Edition"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/txtBrand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/txtStock"
        android:layout_marginTop="6dp"/>

    <!-- Category -->
    <TextView
        android:id="@+id/txtCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category: Smartphones"
        android:textColor="#9E9E9E"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Price -->
    <TextView
        android:id="@+id/txtPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$999"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/txtCategory"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Old Price -->
    <TextView
        android:id="@+id/txtOldPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$1,136"
        android:textColor="#9E9E9E"
        android:textSize="16sp"
        android:layout_marginStart="10dp"
        app:layout_constraintBottom_toBottomOf="@id/txtPrice"
        app:layout_constraintStart_toEndOf="@id/txtPrice"/>

    <!-- Rating -->
    <TextView
        android:id="@+id/txtRating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⭐ 4.8"
        android:textColor="#FFD54F"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/txtPrice"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Reviews -->
    <TextView
        android:id="@+id/txtReviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" | 1,248 Reviews"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/txtRating"
        app:layout_constraintBottom_toBottomOf="@id/txtRating"/>

    <!-- Sold -->
    <TextView
        android:id="@+id/txtSold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" | 5k+ Sold"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/txtReviews"
        app:layout_constraintBottom_toBottomOf="@id/txtRating"/>

    <!-- Description Title -->
    <TextView
        android:id="@+id/txtDescriptionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/txtRating"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Description -->
    <TextView
        android:id="@+id/txtDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#B0BEC5"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:text="Experience the peak of performance with the latest Apple smartphone. Powered by the incredibly fast A15 Bionic chip..."
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtDescriptionTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

